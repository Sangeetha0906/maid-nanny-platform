# Required for Atlas Connection
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/maid-nanny-db

# Secret for JWT authentication (e.g., a long random string)
JWT_SECRET=your_super_secret_key_here

# Your live frontend URL (e.g., https://your-app.vercel.app)
FRONTEND_URL=http://localhost:5173

# Port for the server (provided by Render automatically)
PORT=5000
